# ── Sensitive / generated per-machine ──────────────────────────────────────
# These are created automatically on first run and must NEVER be committed.
# Each user generates their own copies locally.

config.json        # PIN hash (PBKDF2-SHA256) — unique per user
cert.pem           # TLS certificate — generated for your local IP
key.pem            # TLS private key — NEVER share this
ssl.cnf            # OpenSSL config used to generate the cert

# ── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/
.env

# ── macOS system files ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?
Thumbs.db

# ── Logs & temp files ────────────────────────────────────────────────────────
*.log
maccontrol.log
nohup.out
/tmp/msmr_*

# ── Release artifacts (generated by release.sh) ──────────────────────────────
releases/

# ── Editor / IDE ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/
